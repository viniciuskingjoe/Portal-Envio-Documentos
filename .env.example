# Porta do app (próxima livre na VM AKR = 3003)
PORT=3003

# Segredo da sessão — gere um valor fixo em produção:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=troque-por-um-hex-de-64-caracteres

# Cookie seguro: true quando servido via HTTPS (Cloudflare Tunnel). Em dev HTTP, false.
COOKIE_SECURE=false

# SQL Server (KINGEJOE) — banco do Linx + tabelas do portal.
SQLSERVER_HOST=192.168.1.3
SQLSERVER_PORT=1433
SQLSERVER_DATABASE=KINGEJOE
SQLSERVER_USER=vinicius.lopes
SQLSERVER_PASSWORD=
# Instância on-premise sem certificado válido assinado:
SQLSERVER_ENCRYPT=false
SQLSERVER_TRUST_CERTIFICATE=true

# Data de corte: só notas recebidas a partir daqui aparecem no portal.
ENTRADAS_CUTOFF=2026-07-20

# SQLite — legado, ainda em uso durante a migração para o SQL Server.
DB_PATH=/opt/portal-envio-documentos/data.db

# Pasta dos arquivos anexados (default: ./uploads)
UPLOAD_DIR=/opt/portal-envio-documentos/uploads

# Active Directory / LDAP (só confirma identidade no 1º acesso) — DC da empresa
LDAP_URL=ldap://192.168.1.4:389
LDAP_BASE_DN=DC=king,DC=local
LDAP_DOMAIN=king.local

# Administrador(es) inicial(is): sAMAccountName separados por vírgula. No PRIMEIRO
# ACESSO desses logins, a conta já nasce administrador+ativo (resolve o ovo-galinha).
# Depois de ter um admin funcionando, pode esvaziar. Ex.: BOOTSTRAP_ADMIN=vlopes
BOOTSTRAP_ADMIN=
